{
  "name": "k2gl/array-reader",
  "description": "Read typed values from untyped arrays (JSON, CSV, config, request data) in PHP, with strict and lenient modes.",
  "homepage": "https://github.com/k2gl/array-reader",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "array",
    "typed",
    "type-safe",
    "json",
    "phpstan",
    "psalm",
    "dto",
    "casting"
  ],
  "authors": [
    {
      "name": "Nickolay Harin",
      "email": "l0gic@ya.ru"
    }
  ],
  "support": {
    "issues": "https://github.com/k2gl/array-reader/issues",
    "source": "https://github.com/k2gl/array-reader"
  },
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10|^11|^12",
    "phpstan/phpstan": "^2.1",
    "laravel/pint": "~1.20.0",
    "k2gl/phpunit-fluent-assertions": "^12"
  },
  "autoload": {
    "psr-4": {
      "K2gl\\ArrayReader\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "K2gl\\ArrayReader\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse",
    "cs": "pint --test",
    "cs-fix": "pint",
    "check": [
      "@test",
      "@phpstan",
      "@cs"
    ]
  }
}
